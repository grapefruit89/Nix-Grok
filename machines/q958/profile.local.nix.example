# Kopie: cp profile.local.nix.example profile.local.nix
# NIEMALS committen — steht in .gitignore
{
  restic = {
    # optional — leer = kein Healthchecks.io-Ping
    healthcheckUrl = "";
  };
  alerting = {
    # optional — Stufe 8+, leer = kein ntfy/Webhook (OnFailure nur wenn gesetzt)
    ntfyTopic = "";
    webhookUrl = "";
  };
  secrets = {
    devKeys = {
      pocketId.encryptionKey = "CHANGE_ME_min_16_chars";
      grafana.secretKey = "CHANGE_ME";
      context7.apiKey = ""; # leer = set-context7-api-key
      restic.password = "CHANGE_ME";
      vaultwarden.adminToken = "CHANGE_ME";
      amp = {
        adminUser = "admin";
        adminPassword = "CHANGE_ME";
      };
      homeassistant = {
        mqttPassword = "CHANGE_ME";
      };
      zigbee = {
        mqttPassword = "CHANGE_ME";
      };

      # ── Media-Stack API Keys (→ machines/q958/media-secrets.nix) ──────────
      media = {
        # *arr — Pflicht (werden in config.xml injiziert)
        prowlarr.apiKey  = "CHANGE_ME";
        sonarr.apiKey    = "CHANGE_ME";
        radarr.apiKey    = "CHANGE_ME";
        sabnzbd.apiKey   = "CHANGE_ME";
        # Optionale *arr
        lidarr.apiKey    = ""; # leer = kein lidarr_api_key in /var/lib/secrets
        readarr.apiKey   = ""; # leer = kein readarr_api_key
        # Media-Apps (für sync-script.sh falls benötigt)
        jellyfin.apiKey  = ""; # leer = kein jellyfin_api_key
        jellyseerr.apiKey = ""; # leer = kein jellyseerr_api_key
        # Indexer
        scenenzbs.apiKey = "CHANGE_ME";
      };
    };

    # ── Usenet Newsserver-Zugangsdaten ────────────────────────────────────────
    # Alle leer = kein usenet.env, kein usenet_username/password in /var/lib/secrets
    usenet = {
      host     = ""; # z.B. "news.usenetserver.com"
      port     = 563; # Standard SSL-Port
      ssl      = true;
      username = "";
      password = "";
    };

    privado = {
      # WireGuard PrivateKey — landet in /var/lib/secrets/privado.env + privado_private_key
      privateKey = "";
    };
    cloudflare = {
      # Zone.DNS.Edit für m7c5.de — DDNS-Updater + dns-guard; leer = kein DDNS-Config
      apiToken = "";
    };
    # ── Restic Primär-Backup: Koofr 1 TB (S3-API) ───────────────────────────
    # Koofr einrichten: koofr.net → Settings → S3 Access Keys → Key erzeugen
    # Bucket vorher anlegen: koofr.net → Files → "restic-q958" erstellen
    restic = {
      repository = ""; # z.B. "s3:s3.koofr.net/restic-q958/restic"
      awsAccessKeyId = ""; # Koofr S3 Key ID
      awsSecretAccessKey = ""; # Koofr S3 Secret
    };

    # ── Restic Sekundär-Backup: MEGA 50 GB (rclone, E2E) ────────────────────
    # Nur Vaultwarden + Secrets — wöchentlich Sonntag 04:00
    # Passwort obscuren: rclone obscure <dein-mega-passwort>  → Ausgabe als obscuredPass
    resticMega = {
      enable = false; # auf true setzen wenn eingerichtet
      user = ""; # MEGA-Account-E-Mail
      obscuredPass = ""; # Ausgabe von: rclone obscure <passwort>
    };

    oidc = {
      # Pocket-ID → Applications → New → Callback-URL prüfen
      jellyfin  = { clientId = ""; clientSecret = ""; };
      navidrome = { clientId = ""; clientSecret = ""; };
    };
  };
}